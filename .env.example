SERPAPI_KEY=your_serpapi_key_here

DB_HOST=your_db_host
DB_PORT=your_db_port
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Local output — set this to export HTML report to a file (leave empty when deploying)
REPORT_OUTPUT_DIR=/your/preferred/output/folder

# Email output — set these when deploying (leave empty for local)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=you@example.com
NOTIFY_EMAILS=you@example.com,another@example.com
